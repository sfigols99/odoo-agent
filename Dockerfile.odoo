# Imagen Odoo custom que empaqueta el addon odoo_ai (despliegue inmutable).
#
# Build:   docker build -f Dockerfile.odoo -t odoo-ai:18.0 .
# Push:    docker tag odoo-ai:18.0 <registry>/odoo-ai:18.0 && docker push <registry>/odoo-ai:18.0
# Local:   (minikube)  minikube image load odoo-ai:18.0
#          (kind)      kind load docker-image odoo-ai:18.0
FROM odoo:18.0

# Módulos OCA como wheels de PyPI (ver requirements-oca.txt). --no-deps porque
# el wheel declara una dependencia "odoo" que no es pip-instalable en esta
# imagen (Odoo va instalado por paquete de sistema).
USER root
COPY requirements-oca.txt /tmp/requirements-oca.txt
RUN pip3 install --no-cache-dir --no-deps --break-system-packages \
    -r /tmp/requirements-oca.txt
USER odoo

# El addon se monta en /mnt/extra-addons, incluido en addons_path (odoo.conf).
COPY ./addons /mnt/extra-addons

# requests ya es dependencia core de Odoo; no hace falta instalar nada más
# para llamar al endpoint OpenAI-compatible de vLLM.
