<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cada usuario solo ve y gestiona SUS propias conversaciones. -->
    <record id="rule_ai_conversation_own" model="ir.rule">
        <field name="name">Asistente IA: conversaciones propias</field>
        <field name="model_id" ref="model_odoo_ai_conversation"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_ai_message_own" model="ir.rule">
        <field name="name">Asistente IA: mensajes propios</field>
        <field name="model_id" ref="model_odoo_ai_message"/>
        <field name="domain_force">[('conversation_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
