<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate: editables desde Ajustes > Técnico > Parámetros del sistema
         sin que un upgrade del módulo los pise. -->
    <data noupdate="1">
        <record id="cfg_vllm_url" model="ir.config_parameter">
            <field name="key">odoo_ai.vllm_url</field>
            <field name="value">http://vllm-service/v1</field>
        </record>
        <record id="cfg_model" model="ir.config_parameter">
            <field name="key">odoo_ai.model</field>
            <field name="value">Qwen/Qwen2.5-7B-Instruct</field>
        </record>
        <record id="cfg_max_iter" model="ir.config_parameter">
            <field name="key">odoo_ai.max_tool_iterations</field>
            <field name="value">6</field>
        </record>
        <record id="cfg_temperature" model="ir.config_parameter">
            <field name="key">odoo_ai.temperature</field>
            <field name="value">0.1</field>
        </record>
        <record id="cfg_timeout" model="ir.config_parameter">
            <field name="key">odoo_ai.request_timeout</field>
            <field name="value">120</field>
        </record>
        <!-- Fase 0.2: selección dinámica de tools -->
        <record id="cfg_enabled_packs" model="ir.config_parameter">
            <field name="key">odoo_ai.enabled_packs</field>
            <field name="value">all</field>
        </record>
        <record id="cfg_router_threshold" model="ir.config_parameter">
            <field name="key">odoo_ai.router_threshold</field>
            <field name="value">20</field>
        </record>
        <!-- Fase 0.3: turno del agente en job asíncrono (requiere queue_job
             instalado y jobrunner activo: workers>0 + server_wide_modules). -->
        <record id="cfg_async_enabled" model="ir.config_parameter">
            <field name="key">odoo_ai.async_enabled</field>
            <field name="value">0</field>
        </record>
    </data>
</odoo>
